<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="refresh" content="30" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>PlenX AI Dashboard</title>
  <style>
    * { box-sizing: border-box; }

    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: linear-gradient(135deg, #152347, #0b1734);
      color: #fff;
    }

    .wrap {
      width: 96%;
      margin: 20px auto;
    }

    .title {
      font-size: 28px;
      font-weight: 800;
      margin-bottom: 16px;
      text-transform: uppercase;
    }

    .topbar {
      display: flex;
      flex-wrap: wrap;
      gap: 16px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 14px;
      padding: 18px 24px;
      margin-bottom: 20px;
      font-size: 18px;
      font-weight: 700;
      align-items: center;
    }

    .topbar-item {
      min-width: 180px;
    }

    .search-box {
      margin-left: auto;
      position: relative;
      min-width: 250px;
    }

    .search-input {
      background: rgba(255,255,255,0.1);
      border: 1px solid #00ecff;
      border-radius: 8px;
      padding: 10px 15px;
      color: #fff;
      font-size: 16px;
      width: 100%;
      outline: none;
      transition: all 0.3s;
    }

    .search-input:focus {
      background: rgba(255,255,255,0.2);
      box-shadow: 0 0 10px rgba(0,236,255,0.5);
    }

    .table-box {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 14px;
      overflow-x: auto;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      table-layout: fixed;
      min-width: 1450px;
    }

    thead {
      background: rgba(255,255,255,0.05);
    }

    th, td {
      padding: 14px 10px;
      text-align: center;
      border-bottom: 1px solid rgba(255,255,255,0.08);
      font-size: 15px;
      word-break: keep-all;
      vertical-align: middle;
    }

    th {
      font-size: 16px;
      font-weight: 800;
    }

    td.pair {
      font-size: 18px;
      font-weight: 800;
    }

    td.xscore {
      font-size: 18px;
      font-weight: 800;
    }

    .status-entry {
      color: #2df29b;
      font-weight: 800;
    }

    .status-ready {
      color: #ffd34d;
      font-weight: 800;
    }

    .status-wait {
      color: #cfd6e4;
      font-weight: 700;
    }

    .status-skip {
      color: #ff6161;
      font-weight: 800;
    }

    .decision-strong {
      color: #56a8ff;
      font-weight: 800;
    }

    .decision-watch {
      color: #ffd34d;
      font-weight: 800;
    }

    .decision-skip {
      color: #ff6161;
      font-weight: 800;
    }

    .small {
      line-height: 1.5;
      white-space: pre-line;
    }

    .jarvis-cell {
      background: rgba(0,236,255,0.05);
      border: 1px solid #00ecff;
      text-align: left;
      padding-left: 10px;
    }

    .jarvis-title {
      color: #00ecff;
      font-weight: 800;
      font-size: 16px;
    }

    .jarvis-reason {
      font-size: 11px;
      color: #cfd6e4;
      margin-bottom: 5px;
    }

    .jarvis-range {
      padding-top: 5px;
      border-top: 1px solid rgba(255,255,255,0.1);
      line-height: 1.4;
    }

    .jarvis-label {
      color: #9fb0d0;
      font-size: 11px;
    }

    .jarvis-start {
      color: #ffd34d;
      font-size: 14px;
      font-weight: 800;
    }

    .jarvis-end {
      color: #2df29b;
      font-size: 14px;
      font-weight: 800;
    }

    .empty-box {
      padding: 30px;
      text-align: center;
      color: #cfd6e4;
      font-size: 18px;
    }

    @media (max-width: 900px) {
      .title { font-size: 22px; }
      .topbar { font-size: 15px; padding: 14px 16px; gap: 10px; }
      .search-box { width: 100%; margin-top: 5px; }
    }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="title">plen x dashboard</div>

    <div class="topbar">
      <div class="topbar-item">Updated: {{ data.updated_at }}</div>
      <div class="topbar-item">Rows: {{ data.count }}</div>
      <div class="topbar-item">Entry Signals: {{ data.entry_signals if data.entry_signals is defined else 0 }}</div>

      <div class="search-box">
        <input
          type="text"
          id="coinSearch"
          class="search-input"
          placeholder="코인 심볼 검색 (예: BTC, ETH, SOL)"
          onkeyup="filterTable()"
        >
      </div>
    </div>

    <div class="table-box">
      {% if data.rows and data.rows|length > 0 %}
      <table id="mainTable">
        <thead>
          <tr>
            <th style="width:12%">Pair</th>
            <th style="width:5%">Tier</th>
            <th style="width:8%">X-Score</th>
            <th style="width:12%">LONG</th>
            <th style="width:12%">SHORT</th>
            <th style="width:10%">Status</th>
            <th style="width:7%">Quality</th>
            <th style="width:10%">판단</th>
            <th style="width:15%; color:#00ecff; background:rgba(0,236,255,0.1);">🤖 자비스-플렌X</th>
            <th style="width:8%">추천투자금</th>
            <th style="width:6%">승률</th>
            <th style="width:5%">ROI</th>
            <th style="width:5%">SAFE</th>
          </tr>
        </thead>
        <tbody>
          {% for row in data.rows %}
          <tr class="coin-row">
            <td class="pair">{{ row.pair }}</td>
            <td>{{ row.tier }}</td>
            <td class="xscore">{{ row.x_score }}</td>

            <td class="small">
              {% if row.long_start is not none %}
              시작: {{ row.long_start }}<br>종료: {{ row.long_end }}
              {% else %}
              -
              {% endif %}
            </td>

            <td class="small">
              {% if row.short_start is not none %}
              시작: {{ row.short_start }}<br>종료: {{ row.short_end }}
              {% else %}
              -
              {% endif %}
            </td>

            <td>
              {% if row.status in ["LONG_ENTRY", "SHORT_ENTRY"] %}
                <span class="status-entry">{{ row.status }}</span>
              {% elif row.status in ["LONG_READY", "SHORT_READY"] %}
                <span class="status-ready">{{ row.status }}</span>
              {% elif row.status in ["SKIP", "패스"] %}
                <span class="status-skip">{{ row.status }}</span>
              {% else %}
                <span class="status-wait">{{ row.status }}</span>
              {% endif %}
            </td>

            <td>{{ row.quality }}</td>

            <td>
              {% if row.decision == "진입강력" %}
                <span class="decision-strong">● {{ row.decision }}</span>
              {% elif row.decision == "주의관찰" %}
                <span class="decision-watch">● {{ row.decision }}</span>
              {% elif row.decision == "제외" %}
                <span class="decision-skip">● {{ row.decision }}</span>
              {% else %}
                {{ row.decision }}
              {% endif %}
            </td>

            <td class="jarvis-cell">
              <div class="jarvis-title">{{ row.jarvis_status if row.jarvis_status else "WAITING" }}</div>
              <div class="jarvis-reason">{{ row.jarvis_reason if row.jarvis_reason else "분석 대기 중..." }}</div>

              {% if row.jarvis_start is defined and row.jarvis_start not in ["", "-", none] %}
              <div class="jarvis-range">
                <span class="jarvis-label">시작:</span>
                <b class="jarvis-start">{{ row.jarvis_start }}</b><br>
                <span class="jarvis-label">종료:</span>
                <b class="jarvis-end">{{ row.jarvis_end }}</b>
              </div>
              {% endif %}
            </td>

            <td>{{ row.recommended_amount }}</td>
            <td>{{ row.winrate }}%</td>
            <td>{{ row.roi }}%</td>
            <td>{{ row.safe }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
      {% else %}
      <div class="empty-box">
        표시할 데이터가 없습니다.
      </div>
      {% endif %}
    </div>
  </div>

  <script>
    function filterTable() {
      var input = document.getElementById("coinSearch");
      var filter = input.value.toUpperCase();
      var tr = document.getElementsByClassName("coin-row");

      for (var i = 0; i < tr.length; i++) {
        var td = tr[i].getElementsByTagName("td")[0];
        if (td) {
          var txtValue = td.textContent || td.innerText;
          tr[i].style.display = txtValue.toUpperCase().indexOf(filter) > -1 ? "" : "none";
        }
      }
    }
  </script>
</body>
</html>
